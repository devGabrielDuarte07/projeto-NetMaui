<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:telas"
    x:Class="telas.AppShell">

    <FlyoutItem Title="Home">
        <ShellContent ContentTemplate="{DataTemplate local:TelaLogado}" />
    </FlyoutItem>

    <FlyoutItem Title="Navegar">
        <ShellContent ContentTemplate="{DataTemplate local:TelaNavegacao}" />
    </FlyoutItem>

    <FlyoutItem Title="Ranking">
        <ShellContent ContentTemplate="{DataTemplate local:RankingPage}" />
    </FlyoutItem>

    <FlyoutItem Title="About">
        <ShellContent ContentTemplate="{DataTemplate local:AboutPage}" />
    </FlyoutItem>
</Shell>