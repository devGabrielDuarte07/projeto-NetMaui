<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="telas.LoginPage"
             Title="LoginPage">



    <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand">
        <Entry WidthRequest="300" Placeholder="Usuário" x:Name="usuarioInput" Margin="0,0,0,20"/>
        <Entry Placeholder="Senha" x:Name="senhaInput" IsPassword="True"/>

        <Button x:Name="btnEntrar" Text="Entrar" Clicked="btnEntrar_Clicked"/>
    </StackLayout>
</ContentPage>